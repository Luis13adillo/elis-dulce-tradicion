# ============================================================================
# Eli's Dulce Tradicion — Example environment file
# ============================================================================
# Copy this to `.env` (frontend + backend share the repo root) and fill in
# real values. NEVER commit the filled-in file — `.env*` is gitignored.
#
# This file lists VARIABLE NAMES ONLY. No real keys or secrets are included.
# Values shown after `=` are safe non-secret defaults or placeholders.
#
# Three runtime surfaces use env vars:
#   1. Frontend (Vite)      -> VITE_* vars, baked into the browser bundle
#   2. Backend (Express)    -> process.env.* (NOTE: backend is largely
#                              undeployed in production; see docs/ARCHITECTURE.md)
#   3. Supabase Edge Funcs  -> set via `supabase secrets set KEY=value`,
#                              NOT from this file. Listed at the bottom for
#                              reference only.
# ============================================================================


# ----------------------------------------------------------------------------
# FRONTEND (Vite) — required
# ----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ----------------------------------------------------------------------------
# FRONTEND (Vite) — optional
# ----------------------------------------------------------------------------
# Express backend base URL. Defaults to http://localhost:3001 in code.
# Used only for: delivery-fee calculation, some analytics calls, generic
# api-client.ts. Core order/payment flows go straight to Supabase.
VITE_API_URL=http://localhost:3001

# Stripe publishable key. Use pk_test_ locally; production uses pk_live_ set
# in Vercel (do NOT put a live key here).
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Google Maps (address autocomplete + geocoding for delivery).
VITE_GOOGLE_MAPS_API_KEY=

# Sentry error tracking (frontend). Optional.
VITE_SENTRY_DSN=

# Custom analytics endpoint for performance metrics (src/lib/performance.ts).
VITE_ANALYTICS_ENDPOINT=

# Web push notifications VAPID public key (src/lib/pwa.ts).
VITE_VAPID_PUBLIC_KEY=


# ----------------------------------------------------------------------------
# BACKEND (Express) — see docs/ARCHITECTURE.md; backend is NOT the production
# runtime path. These matter only if you run `npm run server` locally.
# ----------------------------------------------------------------------------
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Database / Supabase (server-side)
DATABASE_URL=postgresql://user:password@host:5432/dbname
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # admin privileges — keep secret
SUPABASE_ANON_KEY=your-anon-key-here

# Auth / security
ADMIN_API_KEY=                                         # required in production for x-api-key auth
CSRF_SECRET=change-in-production
FRONTEND_URL=http://localhost:5178                     # CORS allowlist + email links

# Payments (server-side)
STRIPE_SECRET_KEY=sk_test_your_key_here

# Email (backend fallback path; primary email is via Edge Functions)
RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@elisbakery.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Webhooks / integrations (optional)
ORDER_WEBHOOK_URL=
MAKE_COM_WEBHOOK_URL=
MAKE_COM_WHATSAPP_WEBHOOK=
MERCHANT_EMAIL=support@elisbakery.com

# Backend Sentry (not currently wired — see docs/KNOWN_BUGS.md)
SENTRY_DSN=

# Cron auth (shared with Edge Functions)
CRON_SECRET=

# --- Square: DEAD CODE. Do not use. Listed only because referenced in unused
# --- files (sqlite-server.js, payments-sqlite.js). Stripe is the live provider.
# SQUARE_APPLICATION_ID=
# SQUARE_ACCESS_TOKEN=
# SQUARE_LOCATION_ID=
# SQUARE_ENVIRONMENT=sandbox
# SQUARE_WEBHOOK_SECRET=


# ============================================================================
# SUPABASE EDGE FUNCTIONS — DO NOT set these here.
# Set with: supabase secrets set KEY=value
# Listed for reference (names only):
#
#   SUPABASE_URL                 (auto-provided to functions)
#   SUPABASE_SERVICE_ROLE_KEY    (auto-provided to functions)
#   STRIPE_SECRET_KEY            (sk_live_ in production)
#   STRIPE_WEBHOOK_SECRET        (whsec_... for signature verification)
#   RESEND_API_KEY               (email sending)
#   FROM_EMAIL                   (default orders@elisbakery.com)
#   FROM_NAME                    (default "Eli's Bakery")
#   FRONTEND_URL                 (default https://elisbakery.com — email links)
#   OWNER_EMAIL                  (default owner@elisbakery.com — alerts)
#   CRON_SECRET                  (auth for scheduled functions)
# ============================================================================
